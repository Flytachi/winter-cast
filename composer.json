{
    "name": "flytachi/winter-cast",
    "description": "Winter framework cast component",
    "type": "library",
    "license": "MIT",
    "scripts": {
        "test": "phpunit",
        "test-detail": "phpunit --testdox",
        "cs-check": "phpcs .",
        "cs-fix": "phpcbf ."
    },
    "autoload": {
        "psr-4": {
            "Flytachi\\Winter\\Cast\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Flytachi\\Winter\\Cast\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.3",
        "flytachi/winter-base": "^1.0 | ^3.0",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "@stable",
        "squizlabs/php_codesniffer": "@stable"
    },
    "homepage": "https://winterframe.net",
    "support": {
        "issues": "https://github.com/flytachi/winter-cast/issues",
        "source": "https://github.com/flytachi/winter-cast",
        "docs": "https://winterframe.net/packages/cast"
    },
    "authors": [
        {
            "name": "Flytachi",
            "email": "jason.khan.x@gmail.com"
        }
    ]
}
